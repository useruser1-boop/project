@* File: List.cshtml | Author: Team ## | Course: ISTM 415 *@
@model IEnumerable<JasperGreen.Models.Employee>
@{
    ViewData["Title"] = "Employees";
}

<h2>Employees</h2>
@if (TempData["message"] is not null)
{
    <div class="alert alert-success">@TempData["message"]</div>
}

<p><a class="btn btn-success" asp-action="Add">Add Employee</a></p>

<table class="table table-striped table-bordered">
    <thead><tr><th>Name</th><th>Phone</th><th>Email</th><th>Hire Date</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.FullName</td><td>@item.Phone</td><td>@item.Email</td><td>@item.HireDate.ToShortDateString()</td>
            <td>
                <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.EmployeeID">Edit</a>
                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.EmployeeID">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
