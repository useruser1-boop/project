@* File: List.cshtml | Author: Team ## | Course: ISTM 415 *@
@model IEnumerable<JasperGreen.Models.CrewViewModel>
@{
    ViewData["Title"] = "Crews";
}

<h2>Crews</h2>
@if (TempData["message"] is not null)
{
    <div class="alert alert-success">@TempData["message"]</div>
}

<p><a class="btn btn-success" asp-action="Add">Add Crew</a></p>

<table class="table table-striped table-bordered">
    <thead><tr><th>Crew Name</th><th>Foreman</th><th>Member 1</th><th>Member 2</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Crew.CrewName</td>
            <td>@item.Crew.CrewForeman?.FullName</td>
            <td>@item.Crew.CrewMember1?.FullName</td>
            <td>@item.Crew.CrewMember2?.FullName</td>
            <td>
                <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.Crew.CrewID">Edit</a>
                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Crew.CrewID">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
