@model JasperGreen.Models.CrewViewModel
@{
    ViewData["Title"] = Model.Crew.CrewID == 0 ? "Add Crew" : "Edit Crew";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="@(Model.Crew.CrewID == 0 ? "Add" : "Edit")" method="post">
    <input type="hidden" asp-for="Crew.CrewID" />
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Crew.CrewName" class="form-label"></label>
        <input asp-for="Crew.CrewName" class="form-control" />
        <span asp-validation-for="Crew.CrewName" class="text-danger"></span>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="Crew.CrewForemanID" class="form-label">Crew Foreman</label>
            <select asp-for="Crew.CrewForemanID" asp-items="Model.Employees" class="form-select"></select>
            <span asp-validation-for="Crew.CrewForemanID" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Crew.CrewMember1ID" class="form-label">Crew Member 1</label>
            <select asp-for="Crew.CrewMember1ID" asp-items="Model.Employees" class="form-select"></select>
            <span asp-validation-for="Crew.CrewMember1ID" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Crew.CrewMember2ID" class="form-label">Crew Member 2</label>
            <select asp-for="Crew.CrewMember2ID" asp-items="Model.Employees" class="form-select"></select>
            <span asp-validation-for="Crew.CrewMember2ID" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-3"><button type="submit" class="btn btn-success">Save</button></div>
</form>

<form asp-action="Cancel" method="post" class="mt-2"><button type="submit" class="btn btn-secondary">Cancel</button></form>
